# Plantilla de env vars para platform/.
# Copia este archivo como `.env.local` (gitignored) y rellena los valores
# del proyecto Supabase si quieres activar el backend real. Sin estos
# valores, la plataforma usa el backend local (localStorage, sin auth).

# Supabase (Fase P)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry (Fase R, opcional)
# VITE_SENTRY_DSN=

# PostHog / analytics (Fase R, opcional)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.posthog.com
